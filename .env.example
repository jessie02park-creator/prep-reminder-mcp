# 공공데이터포털(data.go.kr)에서 발급
# 1. "기상청_단기예보 조회서비스" 검색 → 활용신청
KMA_SERVICE_KEY=

# 2. "한국환경공단_에어코리아_대기오염정보" 검색 → 활용신청
AIRKOREA_SERVICE_KEY=

# 카카오 디벨로퍼스(developers.kakao.com)에서 발급
# 카카오 로그인 → 토큰 발급 받은 액세스 토큰 (테스트용, 본인 계정 기준)
KAKAO_ACCESS_TOKEN=

# 카카오 디벨로퍼스 앱의 REST API 키 (카카오맵 장소검색용)
# 앱 관리 페이지 > [카카오맵] > 사용 설정 ON 필요
KAKAO_REST_API_KEY=

# (선택) Anthropic API 키 - 장소 추천에 AI 큐레이션을 추가하고 싶을 때만 필요
# 없으면 자동으로 거리순 fallback 로직을 사용함 (서비스 동작에 필수 아님)
# console.anthropic.com 에서 발급, 결제수단 등록 필요
ANTHROPIC_API_KEY=
